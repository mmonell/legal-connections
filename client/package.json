{
  "name": "legal-connections-webapp",
  "version": "0.4.0",
  "description": "Legal Connections — guided accident referral intake webapp",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev public --compatibility-date=2026-01-01",
    "test": "node --test functions/",
    "db:migrate:local": "wrangler d1 migrations apply legal-connections --local",
    "db:migrate:remote": "wrangler d1 migrations apply legal-connections --remote",
    "deploy": "wrangler pages deploy public"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "wrangler": "^3"
  }
}
